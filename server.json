{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.md-log/md-log-mcp",
  "description": "md-log MCP: save/update/fetch markdown by path (stdio + remote HTTP, PAT auth).",
  "version": "1.1.3",
  "repository": {
    "url": "https://github.com/md-log/md-log-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "md-log-mcp",
      "version": "1.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MDLOG_API_BASE_URL",
          "description": "md-log backend API base URL (must include /api/v1)",
          "isRequired": true,
          "default": "https://app.md-log.com/api/v1"
        },
        {
          "name": "MDLOG_PAT",
          "description": "md-log Personal Access Token (mdlog_pat_...)",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
