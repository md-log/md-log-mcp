# md-log-mcp environment
#
# Full backend API base, INCLUDING the /api/v1 suffix. The client does NOT
# append a version segment — give it the complete base URL.
#   local:  http://localhost:8080/api/v1
#   prod:   https://md.example.com/api/v1
MDLOG_API_BASE_URL=http://localhost:8080/api/v1

# Personal Access Token minted in the md-log web app (Settings -> Tokens).
# Shown in plaintext exactly once. Store it in the OS keychain, never commit it.
# Required for stdio mode (md-log-mcp). IGNORED by remote HTTP mode (md-log-mcp-http),
# where each request carries its own Authorization: Bearer <PAT> header instead.
MDLOG_PAT=mdlog_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Remote Streamable HTTP mode (md-log-mcp-http) --------------------------
# Only used by the HTTP bin. The PAT is NOT read from env in this mode.
#
# Bind interface. Localhost-only by default; set 0.0.0.0 ONLY behind a TLS reverse proxy.
MDLOG_HTTP_HOST=127.0.0.1
# TCP port to listen on.
MDLOG_HTTP_PORT=8787
# The single MCP endpoint path (POST/GET/DELETE).
MDLOG_HTTP_PATH=/mcp
# Comma-separated browser Origin allowlist (DNS-rebinding defense). A request that CARRIES an
# Origin not on this list is rejected; non-browser MCP clients (no Origin header) are allowed.
# MDLOG_HTTP_ALLOWED_ORIGINS=https://app.example.com,https://studio.example.com
# Optional comma-separated Host allowlist (extra DNS-rebinding defense).
# MDLOG_HTTP_ALLOWED_HOSTS=mcp.example.com
# Max request body size in bytes (base64 images inflate ~33%). Default 32 MiB.
# MDLOG_HTTP_MAX_BODY_BYTES=33554432
