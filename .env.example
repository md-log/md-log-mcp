# md-log-mcp environment
#
# Full backend API base, INCLUDING the /api/v1 suffix. The client does NOT
# append a version segment — give it the complete base URL.
#   local:  http://localhost:8080/api/v1
#   prod:   https://md.example.com/api/v1
MDLOG_API_BASE_URL=http://localhost:8080/api/v1

# Personal Access Token minted in the md-log web app (Settings -> Tokens).
# Shown in plaintext exactly once. Store it in the OS keychain, never commit it.
MDLOG_PAT=mdlog_pat_xxxxxxxxxxxxxxxxxxxxxxxx
